# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=prodapt_capstone
MONGO_NORMALIZED_COLLECTION=normalized_candidates
MONGO_SOURCE_COLLECTION=source_1st_resumes
MONGO_GUARDRAIL_AUDIT_COLLECTION=guardrail_audit_logs
MONGO_RAW_ESCO_SKILLS_COLLECTION=raw_esco_skills
MONGO_RAW_ESCO_OCCUPATIONS_COLLECTION=raw_esco_occupations
MONGO_RAW_ESCO_ISCO_GROUPS_COLLECTION=raw_esco_isco_groups

# -----------------------------------------------------------------------------
# Milvus / Zilliz
# -----------------------------------------------------------------------------
MILVUS_URI=https://your-zilliz-endpoint
MILVUS_TOKEN=replace-with-token
MILVUS_DB_NAME=default
MILVUS_OCC_COLLECTION=occupation_collection
MILVUS_SKILL_COLLECTION=skill_collection
MILVUS_CANDIDATE_COLLECTION=candidate_search_collection_v3
MILVUS_METRIC_TYPE=COSINE
MILVUS_SEARCH_EF=128

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL_QUERY_UNDERSTANDING=gpt-4.1-mini
OPENAI_MODEL_QUERY_BUILDER=gpt-4.1-mini
OPENAI_MODEL_CROSS_ENCODER=
OPENAI_MODEL_AGENT_SCORING=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Normalization thresholds
# -----------------------------------------------------------------------------
NORMALIZER_HIGH_THRESHOLD=0.85
NORMALIZER_MEDIUM_THRESHOLD=0.60

# -----------------------------------------------------------------------------
# Stage caps (vector100 + keyword100 -> fusion50 -> cross50 -> rerank20)
# -----------------------------------------------------------------------------
VECTOR_TOP_K=100
KEYWORD_TOP_K=100
FUSION_TOP_K=50
CROSS_ENCODER_TOP_K=50
RERANK_TOP_K=20

# -----------------------------------------------------------------------------
# Score weights
# -----------------------------------------------------------------------------
VECTOR_SKILL_WEIGHT=0.5
VECTOR_OCCUPATION_WEIGHT=0.5
FUSION_STRATEGY=weighted_sum
FUSION_VECTOR_WEIGHT=0.5
FUSION_KEYWORD_WEIGHT=0.5
FUSION_RRF_K=60
CROSS_ENCODER_ENABLED=true

# -----------------------------------------------------------------------------
# Agent scoring (FR-04)
# -----------------------------------------------------------------------------
SEARCH_AGENT_CANDIDATE_TOPN=20
AGENT_MAX_PARALLEL=4
AGENT_TIMEOUT_SEC=60
ORCHESTRATOR_TIMEOUT_SEC=90
INTEGRATED_RETRIEVAL_WEIGHT=0.60
INTEGRATED_FR04_WEIGHT=0.40
FR04_WEIGHT_SKILL=0.40
FR04_WEIGHT_EXPERIENCE=0.35
FR04_WEIGHT_EDUCATION=0.10
FR04_WEIGHT_CAREER=0.075
FR04_WEIGHT_SOFT_SKILL=0.075

# -----------------------------------------------------------------------------
# Guardrails (FR-07)
# -----------------------------------------------------------------------------
INPUT_GUARDRAIL_ENABLED=true
INPUT_GUARDRAIL_MIN_QUERY_LENGTH=20
INPUT_GUARDRAIL_MAX_QUERY_LENGTH=2000
INPUT_GUARDRAIL_REQUIRE_SKILL_OR_OCCUPATION=false
INPUT_GUARDRAIL_PROHIBITED_TERMS_CSV=
OUTPUT_AUDIT_ENABLED=true
OUTPUT_AUDIT_PROHIBITED_TERMS_CSV=
OUTPUT_AUDIT_SAFE_SUMMARY_TEMPLATE=This recommendation was generated from job-relevant evidence.
OUTPUT_AUDIT_SAFE_REASON_TEMPLATE=Details were sanitized by output guardrail policy.

# -----------------------------------------------------------------------------
# DeepEval live harness (FR-08)
# -----------------------------------------------------------------------------
RUN_LIVE_EVALS=false
EVAL_ENFORCE_THRESHOLDS=false
EVAL_MODEL=gpt-4.1-mini
EVAL_CASE_LIMIT=1
EVAL_RETRIEVAL_TOPK=5
EVAL_SEARCH_RESULT_TOPN=1
EVAL_RESUME_MAX_CHARS=2000
EVAL_EXPERIENCE_ITEMS=4
EVAL_SKILL_LIMIT=24
EVAL_OCCUPATION_LIMIT=12
EVAL_FAITHFULNESS_THRESHOLD=0.60
EVAL_ANSWER_RELEVANCY_THRESHOLD=0.50
EVAL_CONTEXTUAL_PRECISION_THRESHOLD=0.50
EVAL_CONTEXTUAL_RELEVANCY_THRESHOLD=0.50
EVAL_SKILL_COVERAGE_THRESHOLD=0.50
EVAL_EXPERIENCE_FIT_THRESHOLD=0.50
EVAL_BIAS_THRESHOLD=0.30
