Project normalized_resume_profile {
  database_type: 'PostgreSQL'
  Note: '''
    Normalized resume schema. ESCO is used as reference DB; normalized result is stored here.
    Field mapping: see docs/field-mapping.md for full source_section / extractor_mode details.
  '''
}

// ────────────────────────────────────────────────────────────────
// HTML Section Types (from Issue #6 re-analysis):
//   NAME (99.8%) | SUMM (99.9%) | HILT (90.5%) | EXPR (100.0%)
//   EDUC (99.6%) | SKLL (96.5%) | TSKL (1.9%)  | ACCM (52.4%)
//   AFIL (31.4%) | ADDI (20.4%) | CERT (13.4%)
//
// Extractor modes:
//   as_is | generated | regex | heuristic | esco_matcher | computed | llm_fallback
// ────────────────────────────────────────────────────────────────

Table candidates {
  candidate_id varchar [pk, note: 'generated: UUID v4']
  source_dataset varchar [not null, note: 'as_is: "1st_data" | "2nd_data" | ...']
  source_record_id varchar [not null, note: 'as_is: MongoDB source_record_id']
  normalizer_version varchar [not null, note: 'generated: script version string']
  normalized_at timestamp [not null, note: 'generated: execution timestamp']
  normalization_status varchar [not null, note: 'computed: success | partial | failed']

  current_location varchar [note: 'section=NAME, mode=regex→llm_fallback, pattern: City, ST']
  resume_text text [not null, note: 'as_is: full resume_text from source']
  extraction_confidence decimal(6,5) [note: 'computed: weighted avg of child confidences']

  indexes {
    (source_dataset, source_record_id) [unique, name: 'uq_candidates_source_record']
    (normalization_status) [name: 'idx_candidates_status']
    (normalized_at) [name: 'idx_candidates_normalized_at']
  }
}

Table candidate_occupation_candidates {
  // source_section: NAME (title) > SUMM (occupation phrase) > EXPR (job titles)
  id bigint [pk, increment]
  candidate_id varchar [not null, ref: > candidates.candidate_id]

  raw_text text [not null, note: 'section=NAME>SUMM>EXPR, mode=heuristic']
  esco_id varchar [note: 'mode=esco_matcher: exact→alt→fuzzy→graph']
  preferred_label varchar [note: 'mode=esco_matcher']
  confidence decimal(6,5) [not null, note: 'mode=esco_matcher']

  match_method varchar [not null, note: 'exact | alt_label | fuzzy | embedding | llm']
  rank int [not null, note: 'computed: confidence DESC']
  is_primary boolean [not null, default: false, note: 'computed: rank=1→true']

  hierarchy_json jsonb [note: 'mode=esco_matcher: broaderRelationsOccPillar']
  source_span text [note: 'heuristic: extraction position info']

  indexes {
    (candidate_id, rank) [name: 'idx_occ_candidate_rank']
    (candidate_id, is_primary) [name: 'idx_occ_candidate_primary']
    (esco_id) [name: 'idx_occ_esco_id']
  }
}

Table candidate_skill_candidates {
  // source_section: SKLL > HILT > TSKL > EXPR (supplementary)
  id bigint [pk, increment]
  candidate_id varchar [not null, ref: > candidates.candidate_id]

  raw_text text [not null, note: 'section=SKLL>HILT>TSKL>EXPR, mode=heuristic, split by comma/bullet/semicolon']
  esco_id varchar [note: 'mode=esco_matcher: exact→alt→fuzzy']
  preferred_label varchar [note: 'mode=esco_matcher']
  confidence decimal(6,5) [not null, note: 'mode=esco_matcher']

  match_method varchar [not null, note: 'exact | alt_label | fuzzy | embedding | llm']
  rank int [not null, note: 'computed: confidence DESC']
  is_primary boolean [not null, default: false, note: 'computed: rank=1→true']

  hierarchy_json jsonb [note: 'mode=esco_matcher: broaderRelationsSkillPillar']
  source_span text [note: 'heuristic: extraction position info']

  indexes {
    (candidate_id, rank) [name: 'idx_skill_candidate_rank']
    (candidate_id, is_primary) [name: 'idx_skill_candidate_primary']
    (esco_id) [name: 'idx_skill_esco_id']
  }
}

Table candidate_experiences {
  // source_section: EXPR (split into multiple records per job block)
  experience_id bigint [pk, increment]
  candidate_id varchar [not null, ref: > candidates.candidate_id]

  title varchar [note: 'section=EXPR, mode=regex→llm_fallback']
  raw_title varchar [note: 'section=EXPR, mode=heuristic: pre-normalization text']
  company varchar [note: 'section=EXPR, mode=regex→llm_fallback, pattern: Company Name']
  start_date date [note: 'section=EXPR, mode=regex, pattern: MM/YYYY | Month YYYY']
  end_date date [note: 'section=EXPR, mode=regex, Current/Present→null+is_current']
  is_current boolean [not null, default: false, note: 'section=EXPR, mode=heuristic']
  location varchar [note: 'section=EXPR, mode=regex, pattern: City, State']
  duration_months int [note: 'computed: end_date - start_date in months']
  description_raw text [note: 'section=EXPR, mode=as_is: full job block text']

  indexes {
    (candidate_id) [name: 'idx_exp_candidate']
    (candidate_id, start_date, end_date) [name: 'idx_exp_candidate_period']
  }
}

Table experience_occupation_candidates {
  // source: candidate_experiences.title → ESCO matching
  id bigint [pk, increment]
  experience_id bigint [not null, ref: > candidate_experiences.experience_id]

  raw_text text [not null, note: 'from experience.title, mode=heuristic']
  esco_id varchar [note: 'mode=esco_matcher: exact→alt→fuzzy→graph']
  preferred_label varchar [note: 'mode=esco_matcher']
  confidence decimal(6,5) [not null, note: 'mode=esco_matcher']

  match_method varchar [not null, note: 'exact | alt_label | fuzzy | embedding | llm']
  rank int [not null, note: 'computed: confidence DESC']
  is_primary boolean [not null, default: false, note: 'computed: rank=1→true']

  hierarchy_json jsonb [note: 'mode=esco_matcher: broaderRelationsOccPillar']

  indexes {
    (experience_id, rank) [name: 'idx_exp_occ_rank']
    (experience_id, is_primary) [name: 'idx_exp_occ_primary']
    (esco_id) [name: 'idx_exp_occ_esco_id']
  }
}

Table candidate_educations {
  // source_section: EDUC (split into multiple records per education block)
  education_id bigint [pk, increment]
  candidate_id varchar [not null, ref: > candidates.candidate_id]

  institution varchar [note: 'section=EDUC, mode=regex→llm_fallback, max 100 chars guard']
  degree varchar [note: 'section=EDUC, mode=regex→llm_fallback, pattern: Bachelor|Master|PhD|Associate']
  field_of_study varchar [note: 'section=EDUC, mode=regex→llm_fallback, pattern: in [Field] | : [Field]']
  start_date date [note: 'section=EDUC, mode=regex, YYYY pattern']
  end_date date [note: 'section=EDUC, mode=regex, YYYY pattern']
  graduation_year varchar [note: 'section=EDUC, mode=regex, fallback to end_date year']
  location varchar [note: 'section=EDUC, mode=regex, pattern: City, State']

  indexes {
    (candidate_id) [name: 'idx_edu_candidate']
  }
}
