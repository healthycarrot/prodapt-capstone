Project esco_minimal_subset {
	database_type: 'PostgreSQL'
	Note: 'Logical schema for storing the minimal ESCO subset used by the resume normalization pipeline. Raw layer uses logical keys (URI/code) and ETL validation, not physical FK constraints.'
}

Table esco_concepts {
	id bigint [pk, increment]
	esco_uri varchar [not null, unique, note: 'Official ESCO concept URI']
	concept_type varchar [not null, note: 'occupation | skill | isco_group | skill_group']
	preferred_label varchar [not null]
	description text
	definition text
	status varchar [note: 'e.g. released']
	language_code varchar [not null, default: 'en']
	skill_type varchar [note: 'Only for skill concepts: knowledge | skill/competence']
	reuse_level varchar [note: 'Only for skill concepts']
	code varchar [note: 'ISCO/skill-group code when present']
	isco_group_code varchar [note: 'Only for occupation concepts']
	source_file varchar [not null, note: 'e.g. occupations_en.csv, skills_en.csv']
	version varchar
	modified_at timestamp

	Note: 'Master table for occupations, skills, ISCO groups, and skill groups.'

	indexes {
		(concept_type, preferred_label) [name: 'idx_esco_concepts_type_label']
		(isco_group_code) [name: 'idx_esco_concepts_isco_group_code']
		(code) [name: 'idx_esco_concepts_code']
	}
}

Table esco_labels {
	id bigint [pk, increment]
	concept_id bigint [not null, ref: > esco_concepts.id]
	label_type varchar [not null, note: 'preferred | alt | hidden']
	label varchar [not null]
	normalized_label varchar [not null, note: 'Lowercased / trimmed / normalized lookup form']
	language_code varchar [not null, default: 'en']
	source_file varchar [not null, note: 'Usually occupations_en.csv or skills_en.csv']

	Note: 'Lookup table for exact match, alt label match, and fuzzy match candidates.'

	indexes {
		(concept_id, label_type) [name: 'idx_esco_labels_concept_type']
		(normalized_label) [name: 'idx_esco_labels_normalized']
		(label) [name: 'idx_esco_labels_raw']
	}
}

Table esco_relations {
	id bigint [pk, increment]
	source_concept_id bigint [not null, ref: > esco_concepts.id]
	target_concept_id bigint [not null, ref: > esco_concepts.id]
	relation_type varchar [not null, note: 'broader | narrower | related | optional | essential | member_of']
	relation_source varchar [not null, note: 'broaderRelationsOccPillar | broaderRelationsSkillPillar | skillSkillRelations | derived']
	source_file varchar [not null]

	Note: 'Generic graph edges for hierarchy traversal and related-concept expansion.'

	indexes {
		(source_concept_id, relation_type) [name: 'idx_esco_relations_source_type']
		(target_concept_id, relation_type) [name: 'idx_esco_relations_target_type']
	}
}

Table esco_occupation_skill_relations {
	id bigint [pk, increment]
	occupation_concept_id bigint [not null, ref: > esco_concepts.id]
	skill_concept_id bigint [not null, ref: > esco_concepts.id]
	relation_type varchar [not null, note: 'essential | optional']
	skill_type varchar [note: 'knowledge | skill/competence']
	source_file varchar [not null, default: 'occupationSkillRelations_en.csv']

	Note: 'Explicit occupation-to-skill edges used for query expansion, validation, and reranking.'

	indexes {
		(occupation_concept_id, relation_type) [name: 'idx_occ_skill_occ_type']
		(skill_concept_id, relation_type) [name: 'idx_occ_skill_skill_type']
		(occupation_concept_id, skill_concept_id) [unique, name: 'uq_occ_skill_pair']
	}
}

Table esco_search_index {
	concept_id bigint [pk, ref: > esco_concepts.id]
	concept_type varchar [not null]
	preferred_label varchar [not null]
	normalized_preferred_label varchar [not null]
	all_labels_text text [not null, note: 'preferred + alt + hidden labels concatenated']
	normalized_all_labels_text text [not null]
	hierarchy_path_text text [note: 'Human-readable broader path for debugging and search enrichment']
	searchable_payload text [not null, note: 'preferred label + labels + short description + hierarchy path']

	Note: 'Denormalized helper table for fast lookup during normalization and semantic candidate generation.'

	indexes {
		(concept_type, normalized_preferred_label) [name: 'idx_esco_search_type_pref']
	}
}

// -----------------------------------------------------------------
// Raw source-aligned minimal subset (CSVに近い形で保持)
// -----------------------------------------------------------------

Table raw_esco_occupations {
	id bigint [pk, increment]
	concept_uri varchar [not null]
	isco_group varchar
	preferred_label varchar
	alt_labels text
	hidden_labels text
	status varchar
	modified_date varchar
	scope_note text
	definition text
	in_scheme text
	description text
	code varchar
	nace_code varchar

	indexes {
		(concept_uri) [unique, name: 'uq_raw_occ_uri']
		(concept_uri) [name: 'idx_raw_occ_uri']
		(isco_group) [name: 'idx_raw_occ_isco_group']
		(preferred_label) [name: 'idx_raw_occ_label']
	}
}

Table raw_esco_skills {
	id bigint [pk, increment]
	concept_uri varchar [not null]
	skill_type varchar
	reuse_level varchar
	preferred_label varchar
	alt_labels text
	hidden_labels text
	status varchar
	modified_date varchar
	scope_note text
	definition text
	in_scheme text
	description text

	indexes {
		(concept_uri) [unique, name: 'uq_raw_skill_uri']
		(concept_uri) [name: 'idx_raw_skill_uri']
		(skill_type) [name: 'idx_raw_skill_type']
		(preferred_label) [name: 'idx_raw_skill_label']
	}
}

Table raw_esco_isco_groups {
	id bigint [pk, increment]
	concept_uri varchar [not null]
	code varchar
	preferred_label varchar
	alt_labels text
	status varchar
	in_scheme text
	description text

	indexes {
		(code) [unique, name: 'uq_raw_isco_code']
		(concept_uri) [name: 'idx_raw_isco_uri']
		(code) [name: 'idx_raw_isco_code']
	}
}

Table raw_esco_skill_groups {
	id bigint [pk, increment]
	concept_uri varchar [not null]
	preferred_label varchar
	alt_labels text
	hidden_labels text
	status varchar
	modified_date varchar
	scope_note text
	in_scheme text
	description text
	code varchar

	indexes {
		(code) [unique, name: 'uq_raw_skill_group_code']
		(concept_uri) [name: 'idx_raw_skill_group_uri']
		(code) [name: 'idx_raw_skill_group_code']
	}
}

Table raw_esco_broader_relations_occ {
	id bigint [pk, increment]
	concept_type varchar
	concept_uri varchar [not null]
	concept_label varchar
	broader_type varchar
	broader_uri varchar [not null]
	broader_label varchar

	indexes {
		(concept_uri) [name: 'idx_raw_broader_occ_concept_uri']
		(broader_uri) [name: 'idx_raw_broader_occ_parent_uri']
	}
}

Table raw_esco_broader_relations_skill {
	id bigint [pk, increment]
	concept_type varchar
	concept_uri varchar [not null]
	concept_label varchar
	broader_type varchar
	broader_uri varchar [not null]
	broader_label varchar

	indexes {
		(concept_uri) [name: 'idx_raw_broader_skill_concept_uri']
		(broader_uri) [name: 'idx_raw_broader_skill_parent_uri']
	}
}

Table raw_esco_occupation_skill_relations {
	id bigint [pk, increment]
	occupation_uri varchar [not null]
	occupation_label varchar
	relation_type varchar
	skill_type varchar
	skill_uri varchar [not null]
	skill_label varchar

	Note: 'Join keys: occupation_uri -> raw_esco_occupations.concept_uri, skill_uri -> raw_esco_skills.concept_uri'

	indexes {
		(occupation_uri, relation_type) [name: 'idx_raw_occ_skill_occ_rel']
		(skill_uri, relation_type) [name: 'idx_raw_occ_skill_skill_rel']
		(occupation_uri, skill_uri, relation_type) [name: 'idx_raw_occ_skill_pair']
	}
}

Table etl_validation_runs {
	id bigint [pk, increment]
	run_at timestamp [not null]
	target_layer varchar [not null, note: 'raw | normalized']
	status varchar [not null, note: 'success | warning | failed']
	note text
}

Table etl_validation_issues {
	id bigint [pk, increment]
	validation_run_id bigint [not null]
	table_name varchar [not null]
	issue_type varchar [not null, note: 'missing_parent | duplicate_key | invalid_code | unresolved_join']
	join_key_name varchar [not null, note: 'concept_uri | skill_uri | occupation_uri | isco_group | code']
	join_key_value varchar [not null]
	record_id bigint
	detail text

	indexes {
		(validation_run_id, table_name) [name: 'idx_etl_issues_run_table']
		(issue_type, join_key_name) [name: 'idx_etl_issues_type_key']
	}
}
