Project mongodb_source_resume_layer {
  database_type: 'PostgreSQL'
  Note: '''
    Logical schema for MongoDB source resume collection managed by:
    - script/pipeline_mongo/ingest_csv_to_mongo.py
    - script/pipeline_mongo/parse_sections_to_mongo.py
    - script/pipeline_mongo/extract_fields_to_mongo.py
    Notes:
    - `_id` is MongoDB ObjectId.
    - DBML tables under "*_embedded" are embedded document shapes, not physical collections.
    - raw_esco_* collections are defined in docs/schema/dbdiagram.raw_esco.dbml.
  '''
}

Table source_1st_resumes {
  _id varchar [pk, note: 'MongoDB ObjectId']
  source_dataset varchar [not null, note: 'Current ingestion path stores "1st_data".']
  source_record_id varchar [not null]
  category varchar
  resume_text text
  resume_html text

  parsed_sections jsonb [note: 'Array of source_1st_parsed_section_embedded.']
  parsing_method varchar [note: 'html | whitespace | none']
  parser_version varchar [note: 'e.g. parse_sections_v1.0']
  section_count int
  section_types jsonb [note: 'Unique section_type list, sorted.']

  extracted_fields jsonb [note: 'Object shape is source_1st_extracted_fields_embedded; null on extraction error.']
  extractor_version varchar [note: 'e.g. extract_fields_v1.0']
  extraction_method varchar [note: 'html | text | none | error']
  experience_count int
  education_count int
  skill_count int

  indexes {
    (source_dataset, source_record_id) [unique, name: 'uq_source_dataset_record']
    (category) [name: 'idx_source_category']
  }
}

Table source_1st_parsed_section_embedded {
  source_doc_id varchar [not null, ref: > source_1st_resumes._id]
  section_type varchar [not null]
  section_id varchar [not null]
  title varchar
  text text [not null]
  char_count int [not null]

  Note: 'Embedded inside source_1st_resumes.parsed_sections.'
}

Table source_1st_extracted_fields_embedded {
  source_doc_id varchar [not null, ref: > source_1st_resumes._id]
  name_title varchar
  current_location varchar
  experiences jsonb [note: 'Array of source_1st_experience_embedded.']
  educations jsonb [note: 'Array of source_1st_education_embedded.']
  skills jsonb [note: 'Array of source_1st_skill_phrase_embedded.']
  occupation_candidates jsonb [note: 'String array from NAME + EXPR titles.']
  extraction_method varchar [note: 'html | text | none']
  extractor_version varchar

  Note: 'Embedded inside source_1st_resumes.extracted_fields.'
}

Table source_1st_experience_embedded {
  source_doc_id varchar [not null, ref: > source_1st_resumes._id]
  title varchar
  raw_title varchar
  company varchar
  start_date varchar [note: 'ISO-ish string: yyyy-MM-dd | yyyy-MM | yyyy']
  end_date varchar [note: 'ISO-ish string: yyyy-MM-dd | yyyy-MM | yyyy']
  is_current boolean
  location varchar
  duration_months int
  description_raw text
  confidence decimal(6,5)

  Note: 'Embedded inside source_1st_resumes.extracted_fields.experiences.'
}

Table source_1st_education_embedded {
  source_doc_id varchar [not null, ref: > source_1st_resumes._id]
  institution varchar
  degree varchar
  field_of_study varchar
  graduation_year varchar
  start_date varchar [note: 'ISO-ish string']
  end_date varchar [note: 'ISO-ish string']
  location varchar
  confidence decimal(6,5)

  Note: 'Embedded inside source_1st_resumes.extracted_fields.educations.'
}

Table source_1st_skill_phrase_embedded {
  source_doc_id varchar [not null, ref: > source_1st_resumes._id]
  raw_text varchar [not null]
  source_section varchar [not null, note: 'SKLL | HILT | TSKL | CERT']

  Note: 'Embedded inside source_1st_resumes.extracted_fields.skills.'
}
