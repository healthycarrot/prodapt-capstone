Project normalized_candidates_current {
  database_type: 'PostgreSQL'
  Note: '''
    Logical schema for MongoDB `normalized_candidates` written by:
    - script/pipeline_mongo/normalize_1st_to_mongo.py
    Version baseline: NORMALIZER_VERSION = issue14_llm_candidate_generation_v2
    Notes:
    - `_id` is MongoDB ObjectId.
    - DBML tables under "*_embedded" are embedded document shapes, not physical collections.
    - Additional Mongo path indexes exist on:
      - llm_handoff.rerank_trigger
      - llm_handoff.extracPtion_trigger
  '''
}

Table normalized_candidates {
  _id varchar [pk, note: 'MongoDB ObjectId']
  candidate_id varchar [note: 'Set only on insert via $setOnInsert UUID v4.']
  source_dataset varchar [not null]
  source_record_id varchar [not null]
  category varchar
  normalizer_version varchar [not null]
  normalized_at timestamp [not null]
  normalization_status varchar [not null, note: 'success | partial | failed']

  current_location varchar
  resume_text text [not null]
  extraction_confidence decimal(6,5)

  occupation_candidates jsonb [not null, note: 'Array of normalized_occupation_candidate_embedded (top 20).']
  skill_candidates jsonb [not null, note: 'Array of normalized_skill_candidate_embedded (top 50).']
  experiences jsonb [not null, note: 'Array of normalized_experience_embedded from extracted_fields.experiences.']
  educations jsonb [not null, note: 'Array of normalized_education_embedded from extracted_fields.educations.']
  llm_handoff jsonb [not null, note: 'Object shape is normalized_llm_handoff_embedded.']
  matching_debug jsonb [not null, note: 'Object shape is normalized_matching_debug_embedded.']

  indexes {
    (source_dataset, source_record_id) [unique, name: 'uq_source_record']
    (candidate_id) [name: 'idx_candidate_id']
    (normalization_status) [name: 'idx_normalization_status']
  }
}

Table normalized_occupation_candidate_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  esco_id varchar [not null]
  preferred_label varchar [not null]
  raw_text text [not null]
  confidence decimal(6,5) [not null]
  match_method varchar [not null, note: 'exact | alt_label | fuzzy | embedding | embedding_b1 | llm_seed']
  rank int [not null]
  is_primary boolean [not null]
  hierarchy_json jsonb [note: 'List[{"id","label"}] from broader relations.']
  source_span text
  base_confidence decimal(6,5) [note: 'Occupation only; set after graph rerank.']
  graph_support jsonb [note: 'Occupation only; {essential_hits, optional_hits, boost}.']

  Note: 'Embedded inside normalized_candidates.occupation_candidates.'
}

Table normalized_skill_candidate_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  esco_id varchar [not null]
  preferred_label varchar [not null]
  raw_text text [not null]
  confidence decimal(6,5) [not null]
  match_method varchar [not null, note: 'exact | alt_label | fuzzy | embedding | embedding_b1 | llm_seed']
  rank int [not null]
  is_primary boolean [not null]
  hierarchy_json jsonb
  source_span text

  Note: 'Embedded inside normalized_candidates.skill_candidates.'
}

Table normalized_experience_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  title varchar
  raw_title varchar
  company varchar
  start_date varchar [note: 'ISO-ish string: yyyy-MM-dd | yyyy-MM | yyyy']
  end_date varchar [note: 'ISO-ish string: yyyy-MM-dd | yyyy-MM | yyyy']
  is_current boolean
  location varchar
  duration_months int
  description_raw text
  confidence decimal(6,5)

  Note: 'Copied from source_1st_resumes.extracted_fields.experiences.'
}

Table normalized_education_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  institution varchar
  degree varchar
  field_of_study varchar
  graduation_year varchar
  start_date varchar [note: 'ISO-ish string']
  end_date varchar [note: 'ISO-ish string']
  location varchar
  confidence decimal(6,5)

  Note: 'Copied from source_1st_resumes.extracted_fields.educations.'
}

Table normalized_llm_handoff_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  rerank_trigger boolean [not null, note: 'Monitoring metadata; not active rerank execution path.']
  extraction_trigger boolean [not null]
  top_occupation_confidence decimal(6,5) [not null]
  top2_margin decimal(6,5)
  top_graph_hits int [not null]
  skill_candidate_count int [not null]

  Note: 'Embedded inside normalized_candidates.llm_handoff.'
}

Table normalized_matching_debug_embedded {
  normalized_doc_id varchar [not null, ref: > normalized_candidates._id]
  ranking_profile varchar [not null, note: 'precision | balanced | coverage']
  threshold_strictness varchar [not null, note: 'strict | medium | lenient']
  fuzzy_thresholds jsonb [not null, note: '{"occupation": float, "skill": float}']
  graph jsonb [not null, note: '{"essential_weight","optional_weight","max_boost","rerank_applied","rank_changed"}']
  embedding jsonb [not null, note: '{"mode","enabled","disabled_reason",candidate_counts...}']
  llm_candidate_generation jsonb [not null, note: '{"mode","enabled","applied","reason",reference_counts,seed_counts,term_counts,"fallback_used"}']
  output_caps jsonb [not null, note: '{"occupation_top_n":20,"skill_top_n":50}']
  category_guardrail jsonb [not null, note: '{"removed_count","removed_examples"}']
  llm_handoff jsonb [not null, note: 'Copy of llm_handoff object at write time.']

  Note: 'Embedded inside normalized_candidates.matching_debug.'
}
